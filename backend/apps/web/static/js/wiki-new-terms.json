[
  // === 1. КАЗАХСТАНСКАЯ СПЕЦИФИКА (20 terms) ===
  {id:101, term:"ЕАЭС", termEn:"Eurasian Economic Union (EAEU)", category:"Казахстан", definition:"Евразийский экономический союз — международная организация региональной экономической интеграции. Члены: Казахстан, Россия, Беларусь, Армения, Кыргызстан. Единое таможенное пространство, свободное движение товаров, услуг, капитала и рабочей силы.", example:"Товары, произведённые в странах ЕАЭС, перемещаются между государствами-членами без уплаты таможенных пошлин.", related:[102,60,55]},
  {id:102, term:"Таможенный кодекс ЕАЭС", termEn:"EAEU Customs Code", category:"Казахстан", definition:"Основной нормативный акт, регулирующий таможенные правоотношения на территории Евразийского экономического союза. Вступил в силу 1 января 2018 года. Определяет порядок таможенного оформления, декларирования, уплаты пошлин и применения таможенных процедур.", example:"Согласно Таможенному кодексу ЕАЭС, срок выпуска товаров не должен превышать 4 часа после регистрации декларации.", related:[101,52,56]},
  {id:103, term:"КТЖ", termEn:"Kazakhstan Temir Zholy (KTZ)", category:"Казахстан", definition:"Қазақстан темір жолы — национальная железнодорожная компания Казахстана. Управляет железнодорожной инфраструктурой протяжённостью более 16 000 км. Крупнейший грузоперевозчик страны, обеспечивает транзитные перевозки Китай — Европа.", example:"КТЖ перевезла 280 млн тонн грузов в 2025 году, из них 25 млн тонн — транзит.", related:[104,34,37]},
  {id:104, term:"KTZ Express", termEn:"KTZ Express", category:"Казахстан", definition:"Дочерняя компания КТЖ, специализирующаяся на контейнерных и мультимодальных перевозках. Оператор контейнерных поездов и терминалов. Ключевой участник Транскаспийского маршрута.", example:"KTZ Express организовала контейнерный поезд Сиань — Алматы с транзитным временем 8 дней.", related:[103,37,96]},
  {id:105, term:"Сухой порт Хоргос", termEn:"Khorgos Dry Port / Khorgos Gateway", category:"Казахстан", definition:"Международный центр приграничного сотрудничества «Хоргос — Восточные ворота» на казахстанско-китайской границе. Крупнейший сухой порт в Центральной Азии. Ежегодная мощность перевалки — более 1 млн TEU. Ключевой пункт смены колеи 1435мм/1520мм.", example:"Через сухой порт Хоргос ежесуточно переваливается до 1 500 контейнеров на маршруте Китай — Европа.", related:[37,36,34,35]},
  {id:106, term:"Порт Актау", termEn:"Port of Aktau", category:"Казахстан", definition:"Международный морской торговый порт на восточном побережье Каспийского моря. Обрабатывает нефтяные, сухие и контейнерные грузы. Стратегический узел Транскаспийского международного транспортного маршрута (ТМТМ).", example:"Порт Актау обработал 5,2 млн тонн грузов, включая 35 000 TEU контейнерных грузов.", related:[107,15,96]},
  {id:107, term:"Порт Курык", termEn:"Port of Kuryk", category:"Казахстан", definition:"Новый паромный и сухогрузный порт на Каспийском море, южнее Актау. Введён в эксплуатацию для разгрузки порта Актау. Специализируется на паромных перевозках Ro-Ro, железнодорожных паромах и сухих грузах.", example:"Паромный терминал порта Курык принимает до 5 паромов в сутки на маршруте Курык — Баку.", related:[106,17,96]},
  {id:108, term:"СЭЗ", termEn:"Special Economic Zone (SEZ)", category:"Казахстан", definition:"Свободная экономическая зона — территория с особым правовым режимом: налоговые льготы, упрощённое таможенное оформление, освобождение от ряда пошлин. В Казахстане действуют 13 СЭЗ, включая «Хоргос — Восточные ворота», «Астана — Технополис», МЦПС «Хоргос».", example:"Резидент СЭЗ «Хоргос» освобождён от НДС, КПН и таможенных пошлин на импортное оборудование сроком на 10 лет.", related:[105,101,120]},
  {id:109, term:"ТМТМ / Средний коридор", termEn:"Trans-Caspian International Transport Route (TITR)", category:"Казахстан", definition:"Транскаспийский международный транспортный маршрут — мультимодальный коридор Китай — Казахстан — Каспийское море — Азербайджан — Грузия — Турция — Европа. Протяжённость ~6 500 км. Транзитное время 12-18 дней. Альтернатива северному маршруту через Россию.", example:"Объём грузов по ТМТМ вырос до 4,2 млн тонн в 2025 году, контейнерный трафик достиг 100 000 TEU.", related:[96,106,107,37]},
  {id:110, term:"Колея 1520мм vs 1435мм", termEn:"Gauge Change 1520/1435mm", category:"Казахстан", definition:"Проблема смены ширины железнодорожной колеи на границе Казахстана и Китая. Казахстан использует колею 1520мм (стандарт СНГ), Китай — 1435мм (международный стандарт). Требуется перестановка вагонов на тележки или перегрузка контейнеров.", example:"На станции Достык/Хоргос перестановка тележек вагона занимает 2-3 часа, перегрузка контейнера — 30 минут.", related:[34,35,33,105]},
  {id:111, term:"Транзитная декларация Т1", termEn:"Transit Declaration T1", category:"Казахстан", definition:"Таможенный документ, оформляемый при транзите товаров через территорию ЕАЭС. Позволяет перемещать грузы от пункта ввоза до пункта назначения или вывоза без уплаты таможенных пошлин. Аналог европейской процедуры T1.", example:"Транзитная декларация Т1 оформлена на контейнер, следующий из Китая через Казахстан в Турцию, сроком на 15 дней.", related:[38,101,102]},
  {id:112, term:"ASTANA-1", termEn:"ASTANA-1 Information System", category:"Казахстан", definition:"Единая автоматизированная информационная система таможенных органов Республики Казахстан. Обеспечивает электронное декларирование, контроль транзита, учёт таможенных платежей. Все таможенные операции в Казахстане проходят через ASTANA-1.", example:"Таможенная декларация была подана через систему ASTANA-1 и выпущена автоматически за 47 минут.", related:[52,102,113]},
  {id:113, term:"QazTrade", termEn:"QazTrade Trade Policy Development Center", category:"Казахстан", definition:"Центр развития торговой политики «QazTrade» при Министерстве торговли и интеграции РК. Осуществляет анализ торговых барьеров, поддержку экспортёров, содействие в выходе на новые рынки, мониторинг транзитных маршрутов.", example:"QazTrade подготовил аналитику по торговым потокам через Средний коридор для экспортёров зерна.", related:[114,109,101]},
  {id:114, term:"KazExport", termEn:"Export Insurance Company KazakhExport", category:"Казахстан", definition:"Экспортная страховая компания «KazakhExport» — инструмент государственной поддержки казахстанского экспорта. Предоставляет страхование экспортных кредитов, торговое финансирование и гарантии для экспортёров.", example:"KazExport застраховал экспортную сделку на $2 млн по поставке металлопроката в Узбекистан.", related:[113,139]},
  {id:115, term:"Kazmortransflot", termEn:"Kazmortransflot", category:"Казахстан", definition:"Национальная морская судоходная компания Казахстана, дочерняя компания КТЖ. Оперирует флотом на Каспийском море: танкеры, сухогрузы, паромы. Обеспечивает морское плечо Транскаспийского маршрута.", example:"Паром Kazmortransflot выполняет 3 рейса в неделю на маршруте Курык — Алят (Баку).", related:[106,107,19]},
  {id:116, term:"Единое окно", termEn:"Single Window", category:"Казахстан", definition:"Система «Единое окно» для участников ВЭД — интегрированная информационная платформа, позволяющая подавать все необходимые документы и сведения через один портал. Сокращает время оформления и количество контактов с госорганами.", example:"Через систему «Единое окно» экспортёр подал декларацию, фитосанитарный сертификат и сертификат происхождения за одну сессию.", related:[112,102,52]},
  {id:117, term:"Национальный оператор", termEn:"National Logistics Operator", category:"Казахстан", definition:"Компания, получившая от государства статус национального оператора в сфере транспорта и логистики. В Казахстане — КТЖ и её дочерние структуры. Отвечает за развитие транспортной инфраструктуры и обеспечение транзитного потенциала.", example:"Национальный оператор инвестировал $300 млн в модернизацию контейнерных терминалов на маршруте ТМТМ.", related:[103,104,109]},
  {id:118, term:"Транзитный потенциал", termEn:"Transit Potential", category:"Казахстан", definition:"Способность страны обеспечивать пропуск транзитных грузов через свою территорию. Казахстан, расположенный между Китаем и Европой, обладает стратегическим транзитным потенциалом — до 30 млн тонн в год.", example:"Развитие инфраструктуры Среднего коридора увеличит транзитный потенциал Казахстана до 10 млн TEU к 2030 году.", related:[109,96,97]},
  {id:119, term:"CAREC коридоры", termEn:"CAREC Corridors", category:"Казахстан", definition:"Программа Центральноазиатского регионального экономического сотрудничества (CAREC) — 6 транспортных коридоров, связывающих Китай, Центральную Азию, Южный Кавказ и Европу. Финансируется АБР и другими международными институтами.", example:"CAREC Коридор 1 (Европа — Восточная Азия) проходит через Хоргос, Алматы и далее через Каспий.", related:[109,97,96]},
  {id:120, term:"ТЛЦ", termEn:"Transport and Logistics Center (TLC)", category:"Казахстан", definition:"Транспортно-логистический центр — крупный мультимодальный хаб, объединяющий складские комплексы, контейнерные терминалы, таможенный пост и сервисную инфраструктуру. В Казахстане строятся ТЛЦ в Алматы, Астане, Актау, Шымкенте.", example:"ТЛЦ «Астана» площадью 50 гектаров обрабатывает 200 000 тонн грузов в год.", related:[36,108,79]},

  // === 2. МЕЖДУНАРОДНЫЕ ПЕРЕВОЗКИ (25 terms) ===
  {id:121, term:"Мультимодальная перевозка", termEn:"Multimodal Transport", category:"Международные перевозки", definition:"Перевозка груза двумя и более видами транспорта по единому договору перевозки, под ответственностью одного оператора (MTO — Multimodal Transport Operator). Один документ покрывает весь маршрут от двери до двери.", example:"Мультимодальная перевозка Шанхай — Алматы: море + ж/д + авто, 22 дня, один оператор, один коносамент.", related:[122,49,50]},
  {id:122, term:"Интермодальная перевозка", termEn:"Intermodal Transport", category:"Международные перевозки", definition:"Перевозка груза в одной грузовой единице (контейнере) последовательно несколькими видами транспорта без перегрузки содержимого. Каждый перевозчик несёт ответственность за свой участок маршрута.", example:"Контейнер проследовал интермодально: авто (Стамбул — Поти) → море (Поти — Актау) → ж/д (Актау — Алматы).", related:[121,50,33]},
  {id:123, term:"Контрейлерная перевозка", termEn:"Piggyback Transport / Combined Transport", category:"Международные перевозки", definition:"Перевозка автомобильных полуприцепов или грузовиков на железнодорожных платформах. Сочетает гибкость автотранспорта с эффективностью железной дороги на дальних расстояниях.", example:"Контрейлерные перевозки из Турции в Казахстан позволяют доставить полуприцеп за 5 дней по ж/д вместо 7 дней по автодороге.", related:[49,31,41]},
  {id:124, term:"Каботаж (международный)", termEn:"Cabotage", category:"Международные перевозки", definition:"Перевозка грузов или пассажиров между пунктами внутри иностранного государства. Обычно ограничивается или запрещается для иностранных перевозчиков с целью защиты национального рынка.", example:"В ЕС каботаж разрешён: до 3 перевозок в течение 7 дней после международной доставки.", related:[8,44]},
  {id:125, term:"Фидерные перевозки", termEn:"Feeder Service", category:"Международные перевозки", definition:"Перевозки грузов между небольшим портом и крупным портом-хабом на малых (фидерных) судах. Обеспечивают подвоз контейнеров к магистральным линиям и развоз от них.", example:"Фидерное судно собирает контейнеры из портов Каспия и доставляет в хаб Стамбул для перегрузки на океанские суда.", related:[131,132,24]},
  {id:126, term:"Проформа-инвойс", termEn:"Pro Forma Invoice", category:"Международные перевозки", definition:"Предварительный счёт, выставляемый продавцом до отгрузки товара. Содержит описание товара, цену, условия поставки. Используется для получения импортной лицензии, открытия аккредитива или оформления предоплаты.", example:"Проформа-инвойс на $450 000 был направлен покупателю для открытия аккредитива в банке.", related:[127,53,61]},
  {id:127, term:"Аккредитив", termEn:"Letter of Credit (L/C)", category:"Международные перевозки", definition:"Обязательство банка произвести платёж продавцу при предъявлении документов, соответствующих условиям аккредитива. Основной инструмент обеспечения платежа в международной торговле. Регулируется правилами UCP 600.", example:"Безотзывный аккредитив на $1,2 млн был открыт в Halyk Bank в пользу поставщика из Китая.", related:[128,126,3]},
  {id:128, term:"Банковская гарантия", termEn:"Bank Guarantee", category:"Международные перевозки", definition:"Обязательство банка выплатить определённую сумму бенефициару, если принципал не выполнит контрактные обязательства. Виды: гарантия исполнения, авансовая гарантия, тендерная гарантия.", example:"Банковская гарантия на 10% от суммы контракта ($120 000) была предоставлена покупателю как обеспечение поставки.", related:[127,129]},
  {id:129, term:"Trade Finance", termEn:"Trade Finance", category:"Международные перевозки", definition:"Торговое финансирование — комплекс финансовых инструментов для обеспечения международных торговых операций: аккредитивы, банковские гарантии, факторинг, форфейтинг, экспортное кредитование.", example:"Банк предложил программу trade finance: аккредитив + постфинансирование на 90 дней под 4,5% годовых.", related:[127,128,114]},
  {id:130, term:"Freight Collect / Freight Prepaid", termEn:"Freight Collect / Freight Prepaid", category:"Международные перевозки", definition:"Условия оплаты фрахта. Freight Prepaid — фрахт оплачен отправителем (при CIF, CFR, CIP, CPT). Freight Collect — фрахт оплачивает получатель (при FOB, FCA, EXW). Указывается в коносаменте.", example:"В коносаменте указано Freight Prepaid — продавец уже оплатил морской фрахт $3 200 до Актау.", related:[7,3,71,73]},
  {id:131, term:"Booking Confirmation", termEn:"Booking Confirmation", category:"Международные перевозки", definition:"Подтверждение бронирования — документ от перевозчика или линейного агента, подтверждающий выделение места на судне/рейсе для конкретного контейнера или груза. Содержит номер букинга, судно, даты, маршрут.", example:"Booking confirmation получен: судно MV Caspian Star, отправление из Поти 15 марта, 2x40'HC.", related:[11,133]},
  {id:132, term:"Shipping Instruction (SI)", termEn:"Shipping Instruction", category:"Международные перевозки", definition:"Инструкция по отправке — документ от грузоотправителя перевозчику с указанием данных для оформления коносамента: данные грузоотправителя, получателя, описание груза, маркировка, особые условия.", example:"SI была подана линейному агенту за 48 часов до погрузки с полными данными для оформления B/L.", related:[131,3,12]},
  {id:133, term:"Cargo Manifest", termEn:"Cargo Manifest", category:"Международные перевозки", definition:"Грузовой манифест — сводный документ, содержащий полный перечень всех грузов на борту транспортного средства (судна, самолёта). Подаётся в таможню порта назначения до прибытия.", example:"Грузовой манифест на 280 контейнеров был передан в таможню порта Актау за 24 часа до прибытия судна.", related:[12,3]},
  {id:134, term:"Stowage Plan", termEn:"Stowage Plan / Bay Plan", category:"Международные перевозки", definition:"План размещения (штивки) грузов на судне. Показывает расположение каждого контейнера в трюмах и на палубе. Учитывает вес, тип груза, порт назначения, опасные грузы.", example:"Согласно stowage plan, рефрижераторные контейнеры размещены на палубе с доступом к электророзеткам.", related:[12,131]},
  {id:135, term:"Transhipment", termEn:"Transhipment / Transshipment", category:"Международные перевозки", definition:"Перегрузка контейнера или груза с одного судна на другое в промежуточном порту. Применяется, когда нет прямого сервиса между портами отправления и назначения.", example:"Контейнер был перегружен (transhipment) в Стамбуле с фидерного судна на океанский контейнеровоз.", related:[33,125,24]},
  {id:136, term:"Фидерное судно", termEn:"Feeder Vessel", category:"Международные перевозки", definition:"Небольшое судно (500-3 000 TEU), обслуживающее короткие маршруты между малыми портами и крупными хабами. Собирает и развозит контейнеры для магистральных линий.", example:"Фидерное судно вместимостью 800 TEU курсирует между портами Каспия и Поти.", related:[137,125,18]},
  {id:137, term:"Океанское судно", termEn:"Mother Vessel / Main Vessel", category:"Международные перевозки", definition:"Крупное магистральное судно (4 000-24 000 TEU), обслуживающее основные океанские маршруты между континентами. Контейнеры подвозятся к нему фидерными судами.", example:"Океанское судно вместимостью 14 000 TEU забирает контейнеры в хабе Стамбул для доставки в Роттердам.", related:[136,18,125]},
  {id:138, term:"Liner Terms", termEn:"Liner Terms", category:"Международные перевозки", definition:"Условия перевозки на линейном судне, при которых стоимость погрузки в порту отправления и выгрузки в порту назначения включена во фрахтовую ставку. Стандартные условия контейнерных линий.", example:"На условиях liner terms фрахт $2 500 включает погрузку в Поти и выгрузку в Актау.", related:[9,7,140]},
  {id:139, term:"Charter Party", termEn:"Charter Party (C/P)", category:"Международные перевозки", definition:"Договор фрахтования судна — юридический документ между судовладельцем и фрахтователем. Определяет условия аренды: маршрут, ставку фрахта, laytime, демередж, обязанности сторон.", example:"Charter party на рейс Актау — Баку предусматривает фрахт $85 000 и 72 часа laytime.", related:[4,140,141]},
  {id:140, term:"Laytime", termEn:"Laytime", category:"Международные перевозки", definition:"Сталийное время — период, отведённый в чартере для погрузки и/или выгрузки судна. Если laytime превышен, фрахтователь платит демередж. Если завершил раньше — получает диспач (бонус).", example:"Laytime на разгрузку — 48 часов. Разгрузка заняла 60 часов, демередж за 12 часов составил $18 000.", related:[5,139,141]},
  {id:141, term:"NOR (Notice of Readiness)", termEn:"Notice of Readiness", category:"Международные перевозки", definition:"Нотис о готовности — уведомление капитана судна грузополучателю или его агенту о прибытии судна в порт и готовности к грузовым операциям. С момента принятия NOR начинает течь laytime.", example:"NOR был подан в 08:00 14 марта, laytime начал течь с 14:00 того же дня согласно условиям чартера.", related:[140,139]},
  {id:142, term:"Чистый коносамент", termEn:"Clean Bill of Lading", category:"Международные перевозки", definition:"Коносамент без оговорок перевозчика о повреждении или неудовлетворительном состоянии груза или упаковки. Банки при аккредитивных расчётах принимают только чистые коносаменты.", example:"Перевозчик выдал чистый коносамент, подтвердив приём 500 коробок в исправном состоянии.", related:[3,127]},
  {id:143, term:"Демередж (контейнерный)", termEn:"Container Demurrage", category:"Международные перевозки", definition:"Плата за использование контейнера на территории порта или терминала сверх бесплатного периода (free time). Стимулирует оперативный вывоз контейнеров. Ставка обычно $50-150 за контейнер в сутки.", example:"Free time — 7 дней. Контейнер простоял 15 дней, демередж за 8 дней составил $800.", related:[5,144]},
  {id:144, term:"Детеншн (контейнерный)", termEn:"Container Detention", category:"Международные перевозки", definition:"Плата за задержку возврата порожнего контейнера после его вывоза с терминала. Начисляется с момента вывоза до возврата. Ставка $30-100 за контейнер в сутки в зависимости от линии.", example:"Клиент вывез контейнер на свой склад, разгрузил и вернул через 10 дней. Детеншн за 5 дней сверх нормы — $400.", related:[6,143]},
  {id:145, term:"Freight Prepaid", termEn:"Freight Prepaid", category:"Международные перевозки", definition:"Условие оплаты перевозки, при котором фрахт оплачен грузоотправителем до или в момент отгрузки. Указывается в коносаменте. Типично для условий CIF, CFR, CIP, CPT.", example:"В B/L указано Freight Prepaid: продавец оплатил морской фрахт $4 100 на условиях CIF Актау.", related:[130,73,3]},

  // === 3. ТАМОЖНЯ И ВЭД (25 terms) ===
  {id:146, term:"ВЭД", termEn:"Foreign Economic Activity (FEA)", category:"Таможня и ВЭД", definition:"Внешнеэкономическая деятельность — совокупность коммерческих операций с иностранными контрагентами: экспорт, импорт, бартер, лизинг, инвестиции. Регулируется таможенным, валютным и торговым законодательством.", example:"Компания начала ВЭД с экспорта зерна в Турцию, оборот за первый год составил $5 млн.", related:[147,52,101]},
  {id:147, term:"Декларант", termEn:"Declarant", category:"Таможня и ВЭД", definition:"Лицо, подающее таможенную декларацию от своего имени или через таможенного представителя. Декларант несёт ответственность за достоверность заявленных сведений и уплату таможенных платежей.", example:"Декларант — ТОО «АлматыТрейд» подал декларацию на импорт 500 тонн текстиля из Узбекистана.", related:[148,52]},
  {id:148, term:"Таможенный представитель", termEn:"Customs Representative / Customs Broker", category:"Таможня и ВЭД", definition:"Юридическое лицо, включённое в реестр таможенных представителей, совершающее таможенные операции от имени и по поручению декларанта. Несёт солидарную ответственность за уплату таможенных платежей.", example:"Таможенный представитель «КазБрокер» оформил 150 деклараций за месяц со средним временем выпуска 2 часа.", related:[57,147,52]},
  {id:149, term:"Таможенная стоимость", termEn:"Customs Value", category:"Таможня и ВЭД", definition:"Стоимость товара, используемая для расчёта таможенных пошлин и налогов. Определяется по 6 методам (основной — метод по стоимости сделки). Включает стоимость товара, транспортные расходы до границы, страхование.", example:"Таможенная стоимость контейнера электроники определена по методу 1 (стоимость сделки): $85 000 CIF Актау.", related:[150,52,53]},
  {id:150, term:"Таможенная пошлина", termEn:"Customs Duty", category:"Таможня и ВЭД", definition:"Обязательный платёж, взимаемый при перемещении товаров через таможенную границу. Виды: адвалорная (% от стоимости), специфическая (за единицу), комбинированная. Ставки определяются Единым таможенным тарифом ЕАЭС.", example:"Ставка ввозной пошлины на легковые автомобили — 15% от таможенной стоимости плюс €1,4 за 1 см³ объёма двигателя.", related:[149,151,101]},
  {id:151, term:"НДС при импорте", termEn:"Import VAT", category:"Таможня и ВЭД", definition:"Налог на добавленную стоимость, уплачиваемый при ввозе товаров на территорию Казахстана. Ставка — 12% от суммы таможенной стоимости, таможенной пошлины и акциза (при наличии). Уплачивается одновременно с таможенными платежами.", example:"НДС при импорте оборудования стоимостью $100 000: ($100 000 + $5 000 пошлина) × 12% = $12 600.", related:[150,152,149]},
  {id:152, term:"Акцизный сбор", termEn:"Excise Tax / Excise Duty", category:"Таможня и ВЭД", definition:"Косвенный налог на отдельные виды подакцизных товаров: алкоголь, табак, нефтепродукты, автомобили. Уплачивается при импорте или производстве. Ставки установлены Налоговым кодексом.", example:"Акциз на импортное пиво составляет 43 тенге за литр, уплачивается при таможенном оформлении.", related:[150,151]},
  {id:153, term:"Классификация товаров", termEn:"Commodity Classification", category:"Таможня и ВЭД", definition:"Определение кода товара по ТН ВЭД ЕАЭС (гармонизированная система, 10 знаков). От кода зависят ставка пошлины, НДС, необходимость лицензий и сертификатов. Ошибка в классификации влечёт штрафы.", example:"Товар «фитнес-трекер» классифицирован по коду 8517.62 (приёмная аппаратура) со ставкой пошлины 0%.", related:[51,149,150]},
  {id:154, term:"Страна происхождения", termEn:"Country of Origin", category:"Таможня и ВЭД", definition:"Страна, в которой товар был полностью произведён или подвергнут достаточной переработке. Определяет возможность применения преференциальных ставок пошлин, антидемпинговых мер, эмбарго.", example:"Страна происхождения — Китай. Применяется ставка ЕТТ ЕАЭС 5%. Если бы происхождение было ЕС — тоже 5%, но без антидемпинга.", related:[55,155]},
  {id:155, term:"Преференциальный режим", termEn:"Preferential Treatment", category:"Таможня и ВЭД", definition:"Снижение или отмена ввозных таможенных пошлин для товаров из стран, с которыми заключены торговые соглашения. ЕАЭС имеет соглашения о свободной торговле с СНГ, Вьетнамом, Сингапуром, Сербией, Ираном.", example:"Товар из Вьетнама ввезён по преференциальной ставке 0% вместо 10% благодаря соглашению о свободной торговле ЕАЭС — Вьетнам.", related:[154,150,101]},
  {id:156, term:"Антидемпинговая пошлина", termEn:"Anti-Dumping Duty", category:"Таможня и ВЭД", definition:"Дополнительная пошлина, вводимая для защиты отечественных производителей от импорта товаров по ценам ниже нормальной стоимости (демпинга). Устанавливается по результатам антидемпингового расследования.", example:"Антидемпинговая пошлина 32% введена на импорт стальных труб из Китая в дополнение к базовой пошлине 15%.", related:[150,157]},
  {id:157, term:"Квота", termEn:"Import/Export Quota", category:"Таможня и ВЭД", definition:"Количественное ограничение на ввоз или вывоз определённого товара за период. Тарифная квота позволяет ввезти определённый объём по сниженной ставке; сверх квоты — повышенная ставка.", example:"Тарифная квота на импорт мяса птицы — 140 000 тонн в год по ставке 25%, сверх квоты — 65%.", related:[156,158]},
  {id:158, term:"Лицензия на импорт/экспорт", termEn:"Import/Export License", category:"Таможня и ВЭД", definition:"Разрешительный документ государственного органа на ввоз или вывоз товаров, подлежащих лицензированию: оружие, лекарства, радиоактивные материалы, товары двойного назначения, отдельные виды сырья.", example:"Лицензия на экспорт пшеницы объёмом 50 000 тонн выдана Министерством торговли сроком на 6 месяцев.", related:[157,67]},
  {id:159, term:"Валютный контроль", termEn:"Currency Control", category:"Таможня и ВЭД", definition:"Система мер государственного контроля за валютными операциями участников ВЭД. Банки контролируют соответствие платежей контрактам, сроки репатриации выручки, обоснованность переводов.", example:"Банк запросил контракт и инвойс для подтверждения валютного платежа $250 000 за импорт оборудования.", related:[160,146]},
  {id:160, term:"Паспорт сделки", termEn:"Transaction Passport", category:"Таможня и ВЭД", definition:"Документ валютного контроля, оформляемый в банке при заключении внешнеторгового контракта на сумму свыше установленного порога. Связывает контракт, платежи и таможенные декларации. В Казахстане — учётный номер контракта.", example:"Учётный номер контракта (аналог паспорта сделки) был присвоен банком при регистрации контракта на импорт $500 000.", related:[159,146]},
  {id:161, term:"Таможенный транзит (процедура)", termEn:"Customs Transit Procedure", category:"Таможня и ВЭД", definition:"Таможенная процедура, при которой иностранные товары перемещаются от таможенного органа отправления до таможенного органа назначения без уплаты пошлин, под таможенным контролем и обеспечением.", example:"Груз из Китая помещён под процедуру таможенного транзита на маршруте Хоргос — Актау сроком на 10 дней.", related:[38,111,59]},
  {id:162, term:"Временный ввоз", termEn:"Temporary Importation", category:"Таможня и ВЭД", definition:"Таможенная процедура, при которой иностранные товары ввозятся на определённый срок с полным или частичным освобождением от пошлин, с обязательством обратного вывоза. Для выставочного оборудования, инструментов, транспорта.", example:"Буровое оборудование стоимостью $2 млн ввезено по процедуре временного ввоза на 18 месяцев с частичным освобождением от пошлин.", related:[163,170]},
  {id:163, term:"Переработка на таможенной территории", termEn:"Inward Processing", category:"Таможня и ВЭД", definition:"Таможенная процедура, при которой иностранные товары ввозятся без уплаты пошлин для переработки (сборки, обработки, ремонта) с последующим вывозом готовой продукции. Срок — до 3 лет.", example:"Компания ввезла 100 тонн хлопка-сырца по процедуре переработки, произвела текстиль и экспортировала без уплаты пошлин.", related:[162,164]},
  {id:164, term:"Свободный склад", termEn:"Free Warehouse", category:"Таможня и ВЭД", definition:"Таможенная процедура, при которой товары размещаются на специальном складе без уплаты пошлин и налогов. Возможна переработка, сборка, сортировка. При выпуске на внутренний рынок — уплата платежей.", example:"Электроника хранится на свободном складе 6 месяцев, при продаже в Казахстане — уплата пошлин и НДС.", related:[163,58]},
  {id:165, term:"Реэкспорт", termEn:"Re-export", category:"Таможня и ВЭД", definition:"Таможенная процедура, при которой ранее импортированные товары вывозятся обратно из страны без уплаты или с возвратом уплаченных пошлин и налогов. Применяется при бракованных товарах или транзитных схемах.", example:"Бракованная партия оборудования ($80 000) была реэкспортирована в Китай с возвратом уплаченных пошлин и НДС.", related:[166,170]},
  {id:166, term:"Реимпорт", termEn:"Re-import", category:"Таможня и ВЭД", definition:"Таможенная процедура, при которой ранее экспортированные казахстанские товары ввозятся обратно без уплаты таможенных пошлин. Применяется при возврате непроданных товаров, рекламациях.", example:"100 тонн пшеницы, отклонённой покупателем в Иране по качеству, реимпортированы в Казахстан без пошлин.", related:[165,170]},
  {id:167, term:"Уничтожение", termEn:"Destruction", category:"Таможня и ВЭД", definition:"Таможенная процедура, при которой иностранные товары уничтожаются под таможенным контролем без уплаты пошлин. Применяется для товаров с истекшим сроком годности, дефектных, не соответствующих стандартам.", example:"Партия просроченных лекарств (20 тонн) была уничтожена по процедуре уничтожения на сертифицированном предприятии.", related:[168]},
  {id:168, term:"Отказ в пользу государства", termEn:"Abandonment to the State", category:"Таможня и ВЭД", definition:"Таможенная процедура, при которой импортёр отказывается от товара в пользу государства без уплаты пошлин. Товар переходит в государственную собственность. Применяется, когда расходы на оформление превышают стоимость товара.", example:"Груз пролежал на СВХ 4 месяца, расходы составили $15 000 при стоимости товара $8 000 — оформлен отказ в пользу государства.", related:[167,58]},
  {id:169, term:"Выпуск для внутреннего потребления", termEn:"Release for Domestic Consumption", category:"Таможня и ВЭД", definition:"Основная таможенная процедура импорта: иностранные товары получают статус товаров ЕАЭС после уплаты всех таможенных пошлин, налогов и соблюдения мер нетарифного регулирования.", example:"После уплаты пошлины (5%), НДС (12%) и предоставления сертификата соответствия товар выпущен для внутреннего потребления.", related:[150,151,170]},
  {id:170, term:"Экспорт (таможенная процедура)", termEn:"Export Procedure", category:"Таможня и ВЭД", definition:"Таможенная процедура, при которой товары ЕАЭС вывозятся за пределы таможенной территории для постоянного нахождения. Экспортные пошлины в ЕАЭС применяются к ограниченному перечню товаров (нефть, газ).", example:"Партия ферросплавов (500 тонн, $1,2 млн) оформлена на экспорт из Казахстана в Турцию, экспортная пошлина — 0%.", related:[169,146,67]},

  // === 4. ЦИФРОВАЯ ЛОГИСТИКА (20 terms) ===
  {id:171, term:"TMS", termEn:"Transportation Management System", category:"Цифровая логистика", definition:"Система управления транспортировкой — программное обеспечение для планирования, оптимизации и управления перевозками. Функции: выбор маршрута, расчёт стоимости, отслеживание, управление перевозчиками, аналитика.", example:"Внедрение TMS снизило транспортные расходы на 18% за счёт оптимизации маршрутов и консолидации грузов.", related:[172,79,90]},
  {id:172, term:"ERP", termEn:"Enterprise Resource Planning", category:"Цифровая логистика", definition:"Система планирования ресурсов предприятия — интегрированная платформа для управления всеми бизнес-процессами: финансы, закупки, производство, логистика, продажи, HR. Единая база данных для всех подразделений.", example:"ERP-система SAP связала модули закупок, склада и логистики, обеспечив сквозную видимость цепочки поставок.", related:[171,79,90]},
  {id:173, term:"IoT в логистике", termEn:"Internet of Things in Logistics", category:"Цифровая логистика", definition:"Интернет вещей — сеть датчиков и устройств, подключённых к интернету, для мониторинга грузов и транспорта: температура, влажность, удары, вскрытие, GPS-координаты. Передача данных в реальном времени.", example:"IoT-датчики в рефрижераторном контейнере фиксировали температуру каждые 15 минут и отправляли данные в облако.", related:[175,176,177]},
  {id:174, term:"Blockchain в supply chain", termEn:"Blockchain in Supply Chain", category:"Цифровая логистика", definition:"Технология распределённого реестра для обеспечения прозрачности и неизменности данных в цепи поставок. Применяется для отслеживания происхождения товаров, электронных коносаментов, смарт-контрактов.", example:"Blockchain-платформа TradeLens фиксирует все этапы контейнерной перевозки: от букинга до доставки получателю.", related:[173,179,183]},
  {id:175, term:"Цифровой двойник", termEn:"Digital Twin", category:"Цифровая логистика", definition:"Виртуальная копия физического объекта (склад, порт, цепь поставок), обновляемая в реальном времени данными от IoT-датчиков. Позволяет моделировать сценарии, прогнозировать проблемы, оптимизировать процессы.", example:"Цифровой двойник порта Актау моделирует загрузку причалов и оптимизирует расписание судозаходов.", related:[173,183,184]},
  {id:176, term:"RFID", termEn:"Radio-Frequency Identification", category:"Цифровая логистика", definition:"Технология радиочастотной идентификации — автоматическое считывание данных с электронных меток на расстоянии. Применяется для учёта товаров на складе, инвентаризации, отслеживания контейнеров.", example:"RFID-метки на 50 000 паллет позволяют проводить инвентаризацию склада за 2 часа вместо 3 дней.", related:[173,177,79]},
  {id:177, term:"GPS-трекинг", termEn:"GPS Tracking", category:"Цифровая логистика", definition:"Спутниковое отслеживание местоположения транспортных средств и грузов в реальном времени. Позволяет контролировать маршрут, скорость, остановки, отклонения от маршрута. Данные доступны через веб-платформу или мобильное приложение.", example:"GPS-трекер на контейнере показал, что груз пересёк границу Казахстана и находится в 120 км от Алматы.", related:[173,176,171]},
  {id:178, term:"e-CMR", termEn:"Electronic CMR Consignment Note", category:"Цифровая логистика", definition:"Электронная международная транспортная накладная для автоперевозок. Юридически эквивалентна бумажной CMR. Ускоряет оформление, снижает ошибки, обеспечивает доступ к данным в реальном времени для всех сторон.", example:"e-CMR была оформлена за 5 минут через мобильное приложение, подписана электронной подписью водителя и отправителя.", related:[41,179,171]},
  {id:179, term:"Электронная таможенная декларация", termEn:"Electronic Customs Declaration", category:"Цифровая логистика", definition:"Таможенная декларация, поданная в электронной форме через информационную систему (в Казахстане — ASTANA-1). Ускоряет оформление, снижает коррупцию, позволяет автоматический выпуск по «зелёному коридору».", example:"97% деклараций в Казахстане подаются электронно через ASTANA-1, из них 45% выпускаются автоматически.", related:[112,52,178]},
  {id:180, term:"EDI", termEn:"Electronic Data Interchange", category:"Цифровая логистика", definition:"Электронный обмен данными — стандартизированный формат передачи коммерческих документов (заказы, инвойсы, накладные) между информационными системами партнёров. Стандарты: EDIFACT, ANSI X12, XML.", example:"EDI-интеграция с перевозчиком позволяет автоматически получать статусы доставки каждые 2 часа.", related:[181,171]},
  {id:181, term:"API-интеграция", termEn:"API Integration", category:"Цифровая логистика", definition:"Подключение логистических систем через программные интерфейсы (API) для автоматического обмена данными: ставки, букинги, трекинг, документы. Обеспечивает бесшовную связь между TMS, ERP, WMS и партнёрами.", example:"Через API судоходной линии TMS автоматически получает ставки, бронирует контейнеры и отслеживает их.", related:[180,171,172]},
  {id:182, term:"Облачная логистика", termEn:"Cloud Logistics", category:"Цифровая логистика", definition:"Логистические платформы и системы, размещённые в облаке (SaaS). Преимущества: доступ из любой точки, масштабируемость, низкие начальные инвестиции, автоматические обновления, интеграция между участниками цепи.", example:"Облачная TMS-платформа объединила 45 перевозчиков в единой системе с прозрачными ставками и онлайн-трекингом.", related:[171,181,183]},
  {id:183, term:"Big Data в логистике", termEn:"Big Data in Logistics", category:"Цифровая логистика", definition:"Анализ больших объёмов данных (маршруты, погода, спрос, цены, трафик) для оптимизации логистических решений. Методы: машинное обучение, нейросети, статистический анализ.", example:"Анализ Big Data за 3 года позволил выявить сезонные паттерны спроса и сократить пустые пробеги на 22%.", related:[184,175,182]},
  {id:184, term:"Предиктивная аналитика", termEn:"Predictive Analytics", category:"Цифровая логистика", definition:"Использование статистических моделей и машинного обучения для прогнозирования событий в логистике: задержки, поломки, спрос, загрузка. Позволяет принимать превентивные меры.", example:"Модель предиктивной аналитики предсказала задержку судна на 3 дня, позволив заранее перепланировать доставку.", related:[183,175]},
  {id:185, term:"Автоматизация склада", termEn:"Warehouse Automation", category:"Цифровая логистика", definition:"Применение роботов, конвейеров, автоматических систем хранения и извлечения (AS/RS) для минимизации ручного труда на складе. Увеличивает скорость, точность и снижает затраты.", example:"Автоматизированный склад обрабатывает 10 000 заказов в смену с помощью 50 роботов и 15 операторов.", related:[186,187,79]},
  {id:186, term:"AGV", termEn:"Automated Guided Vehicle", category:"Цифровая логистика", definition:"Автоматически управляемое транспортное средство — робот для перемещения грузов по складу или терминалу без участия человека. Навигация: магнитные ленты, лазеры, камеры, LiDAR.", example:"20 AGV-роботов на складе перемещают паллеты от зоны приёмки к стеллажам со скоростью 2 м/с.", related:[185,187]},
  {id:187, term:"Дрон-доставка", termEn:"Drone Delivery", category:"Цифровая логистика", definition:"Доставка грузов беспилотными летательными аппаратами (дронами). Применяется для last-mile доставки в труднодоступные районы, медикаментов, срочных запчастей. Грузоподъёмность до 25 кг.", example:"Дрон-доставка медикаментов в отдалённые аулы Казахстана сократила время получения лекарств с 2 дней до 3 часов.", related:[186,188]},
  {id:188, term:"Роботизированная сортировка", termEn:"Robotic Sorting", category:"Цифровая логистика", definition:"Автоматическая сортировка посылок и грузов с помощью роботов на основе сканирования штрихкодов, распознавания образов и AI. Скорость — до 10 000 единиц в час.", example:"Роботизированная сортировочная линия распределяет 8 000 посылок в час по 120 направлениям.", related:[185,186]},
  {id:189, term:"Платформенная логистика", termEn:"Platform Logistics / Digital Freight Marketplace", category:"Цифровая логистика", definition:"Цифровые платформы, соединяющие грузоотправителей и перевозчиков напрямую. Аналог Uber для грузоперевозок. Автоматический подбор транспорта, онлайн-оплата, трекинг, рейтинги.", example:"Через логистическую платформу заказчик нашёл перевозчика за 10 минут, ставка на 15% ниже рынка.", related:[171,182,181]},
  {id:190, term:"Машинное зрение", termEn:"Computer Vision in Logistics", category:"Цифровая логистика", definition:"Технология автоматического распознавания образов с помощью камер и AI: считывание номеров контейнеров, контроль повреждений, подсчёт грузов, контроль погрузки. Снижает ручной контроль.", example:"Система машинного зрения на въезде в порт автоматически считывает номера контейнеров и проверяет повреждения.", related:[176,185,173]},

  // === 5. ФИНАНСЫ И СТРАХОВАНИЕ (20 terms) ===
  {id:191, term:"Страхование груза", termEn:"Cargo Insurance", category:"Финансы и страхование", definition:"Защита финансовых интересов грузовладельца от рисков утраты, повреждения или порчи груза во время перевозки и хранения. Покрытие зависит от условий полиса (Institute Cargo Clauses A, B или C).", example:"Страховой полис на условиях ICC(A) покрывает все риски, страховая сумма — 110% от стоимости CIF ($93 500).", related:[63,192,193]},
  {id:192, term:"CIF-стоимость (страховая)", termEn:"CIF Value for Insurance", category:"Финансы и страхование", definition:"Базовая стоимость для расчёта страховой суммы: стоимость товара + фрахт + страховка. Обычно страховая сумма составляет 110% от CIF-стоимости для покрытия упущенной выгоды.", example:"Стоимость товара $80 000, фрахт $5 000, CIF = $85 000. Страховая сумма: $85 000 × 110% = $93 500.", related:[73,191,63]},
  {id:193, term:"All Risks Coverage", termEn:"All Risks / ICC(A)", category:"Финансы и страхование", definition:"Максимальное страховое покрытие по условиям Institute Cargo Clauses (A) — «от всех рисков». Покрывает все риски утраты и повреждения, кроме исключений (износ, задержка, ядерный риск, умысел). Самая дорогая, но полная защита.", example:"Полис ICC(A) покрыл убытки $12 000 от затопления контейнера морской водой при штормовой погоде.", related:[191,194,195]},
  {id:194, term:"FPA (Free of Particular Average)", termEn:"FPA / ICC(C)", category:"Финансы и страхование", definition:"Минимальное страховое покрытие по Institute Cargo Clauses (C). Покрывает только полную гибель груза, общую аварию, выбрасывание за борт, пожар, столкновение. Не покрывает частичные повреждения.", example:"Полис ICC(C) стоит $120, но покрывает только тотальную гибель — при частичном повреждении возмещения не будет.", related:[193,195]},
  {id:195, term:"WA (With Average)", termEn:"WA / ICC(B)", category:"Финансы и страхование", definition:"Среднее страховое покрытие по Institute Cargo Clauses (B). Покрывает риски ICC(C) плюс: землетрясение, молния, смыв за борт, попадание воды в трюм. Не покрывает кражу, небрежность.", example:"Полис ICC(B) покрыл повреждение зерна от попадания морской воды в трюм, возмещение — $45 000.", related:[193,194]},
  {id:196, term:"Полная гибель", termEn:"Total Loss", category:"Финансы и страхование", definition:"Страховое событие, при котором груз полностью утрачен (фактическая гибель) или стоимость восстановления превышает страховую стоимость (конструктивная гибель). Страховщик выплачивает полную страховую сумму.", example:"Судно затонуло с грузом стоимостью $500 000 — страховщик выплатил $550 000 (110% CIF) по полной гибели.", related:[191,197]},
  {id:197, term:"Общая авария", termEn:"General Average", category:"Финансы и страхование", definition:"Институт морского права: убытки, понесённые намеренно для спасения судна и остального груза (выбрасывание части груза за борт, затопление трюма). Расходы распределяются пропорционально между всеми грузовладельцами.", example:"При пожаре на судне капитан объявил общую аварию. Все грузовладельцы (150 контейнеров) участвуют в покрытии убытков пропорционально стоимости грузов.", related:[196,198]},
  {id:198, term:"Спасание", termEn:"Salvage", category:"Финансы и страхование", definition:"Вознаграждение за спасение судна, груза или фрахта от морской опасности. Размер определяется пропорционально стоимости спасённого имущества. Покрывается страховым полисом.", example:"Буксир спас севшее на мель судно с грузом $20 млн. Вознаграждение за спасание — $2 млн, распределённое между страховщиками.", related:[197,191]},
  {id:199, term:"Суброгация", termEn:"Subrogation", category:"Финансы и страхование", definition:"Право страховщика после выплаты возмещения требовать компенсацию от виновника убытка (перевозчика, стивидора, третьего лица). Страховщик «встаёт на место» страхователя в его правах.", example:"После выплаты $35 000 за повреждённый груз, страховщик предъявил суброгационный иск к перевозчику.", related:[191,204]},
  {id:200, term:"Страховая премия", termEn:"Insurance Premium", category:"Финансы и страхование", definition:"Плата страхователя страховщику за страхование груза. Зависит от стоимости груза, маршрута, типа товара, условий покрытия, истории убытков. Обычно 0,1-1,5% от страховой суммы.", example:"Премия за страхование контейнера электроники ($100 000) на маршруте Китай — Алматы составила $350 (0,35%).", related:[191,201]},
  {id:201, term:"Франшиза (страховая)", termEn:"Deductible / Excess", category:"Финансы и страхование", definition:"Сумма убытка, которую страхователь оплачивает самостоятельно. Безусловная франшиза — вычитается из возмещения. Условная — если убыток превышает франшизу, выплачивается полностью.", example:"Франшиза $500. Убыток $3 000 — страховщик выплатит $2 500. Убыток $400 — не покрывается.", related:[200,191]},
  {id:202, term:"Ответственность экспедитора", termEn:"Freight Forwarder Liability", category:"Финансы и страхование", definition:"Ответственность транспортного экспедитора за утрату, повреждение груза или просрочку доставки. Ограничивается условиями договора, национальным законодательством или международными конвенциями (FIATA).", example:"Экспедитор возместил $8 000 за повреждение груза при перегрузке, ответственность ограничена 8,33 SDR/кг.", related:[92,203,204]},
  {id:203, term:"Ответственность перевозчика", termEn:"Carrier Liability", category:"Финансы и страхование", definition:"Ответственность перевозчика за груз с момента принятия до выдачи. Ограничена международными конвенциями: морская — 666,67 SDR/место или 2 SDR/кг; авто (CMR) — 8,33 SDR/кг; ж/д (COTIF) — 17 SDR/кг.", example:"Морской перевозчик возместил убыток по Гаагским правилам: 666,67 SDR × 10 мест = $9 000 вместо реального ущерба $25 000.", related:[202,204]},
  {id:204, term:"SDR", termEn:"Special Drawing Rights", category:"Финансы и страхование", definition:"Специальные права заимствования — расчётная единица МВФ, используемая в международных транспортных конвенциях для определения пределов ответственности перевозчиков. 1 SDR ≈ $1,35.", example:"Предел ответственности по CMR — 8,33 SDR/кг. Для груза весом 1 000 кг: 8 330 SDR ≈ $11 250.", related:[202,203]},
  {id:205, term:"Ограничение ответственности", termEn:"Limitation of Liability", category:"Финансы и страхование", definition:"Максимальная сумма, которую перевозчик или экспедитор обязан выплатить за убыток. Установлена международными конвенциями и не может быть снижена договором (может быть увеличена по соглашению).", example:"Ограничение ответственности морского перевозчика — 2 SDR/кг или 666,67 SDR/место, выплачивается большая сумма.", related:[203,204,202]},
  {id:206, term:"P&I страхование", termEn:"P&I Insurance (Protection & Indemnity)", category:"Финансы и страхование", definition:"Страхование ответственности судовладельца: загрязнение, гибель экипажа, повреждение причала, столкновения, убытки третьих лиц. Предоставляется P&I клубами (взаимные страховые общества судовладельцев).", example:"P&I клуб покрыл убытки $5 млн от разлива нефти при бункеровке в порту Актау.", related:[207,191]},
  {id:207, term:"Страхование корпуса судна", termEn:"Hull Insurance", category:"Финансы и страхование", definition:"Страхование корпуса и механизмов судна от физического повреждения: столкновение, посадка на мель, пожар, шторм. Покрывает ремонт или полную гибель судна.", example:"Страхование корпуса парома на маршруте Курык — Баку обошлось в $180 000 в год при стоимости судна $25 млн.", related:[206,208]},
  {id:208, term:"Военный риск", termEn:"War Risk Insurance", category:"Финансы и страхование", definition:"Дополнительное страхование от военных рисков: боевые действия, мины, пиратство, терроризм, конфискация. Стандартные полисы исключают военные риски — требуется отдельное покрытие.", example:"При проходе через Красное море дополнительная премия за военный риск составила 0,5% от стоимости груза.", related:[207,209]},
  {id:209, term:"Забастовочный риск", termEn:"Strike Risk Insurance", category:"Финансы и страхование", definition:"Страхование от убытков, вызванных забастовками, бунтами, гражданскими волнениями, локаутами. Исключено из стандартных полисов ICC(A/B/C) — покрывается дополнительным условием Institute Strikes Clauses.", example:"Забастовка докеров в порту Поти задержала груз на 12 дней — страховка покрыла дополнительные расходы $4 500.", related:[208,191]},
  {id:210, term:"Claims Procedure", termEn:"Claims Procedure / Претензионный порядок", category:"Финансы и страхование", definition:"Порядок предъявления претензии за убыток: уведомление страховщика/перевозчика, фиксация повреждений (сюрвейерский акт), сбор документов (коносамент, инвойс, акт осмотра), подача претензии в установленный срок.", example:"Претензия на $12 000 подана перевозчику в течение 3 дней после выгрузки с приложением акта сюрвейера и фото повреждений.", related:[199,191,203]},

  // === 6. УПРАВЛЕНИЕ ЦЕПЯМИ ПОСТАВОК (25 terms) ===
  {id:211, term:"Supply Chain Management (SCM)", termEn:"Supply Chain Management", category:"Управление цепями поставок", definition:"Стратегическое управление всеми потоками (товары, информация, финансы) от поставщика сырья до конечного потребителя. Цель — оптимизация затрат, скорости и качества обслуживания при минимизации рисков.", example:"Внедрение SCM-подхода сократило общие затраты на цепь поставок на 12% и время доставки на 5 дней.", related:[89,90,212]},
  {id:212, term:"Demand Planning", termEn:"Demand Planning / Планирование спроса", category:"Управление цепями поставок", definition:"Процесс прогнозирования объёма спроса на продукцию для планирования закупок, производства и логистики. Использует исторические данные, сезонность, маркетинговые планы, рыночные тренды.", example:"Demand planning предсказал 30%-ный рост спроса в ноябре, позволив заранее увеличить запасы на складе.", related:[213,215,183]},
  {id:213, term:"S&OP", termEn:"Sales and Operations Planning", category:"Управление цепями поставок", definition:"Процесс планирования продаж и операций — ежемесячный кросс-функциональный процесс согласования планов продаж, производства, закупок, логистики и финансов. Обеспечивает баланс спроса и предложения.", example:"На встрече S&OP руководители продаж, производства и логистики согласовали план на Q2 с учётом сезонного пика.", related:[212,211,214]},
  {id:214, term:"Procurement (закупки)", termEn:"Procurement", category:"Управление цепями поставок", definition:"Стратегический процесс поиска, оценки и привлечения поставщиков, ведения переговоров, заключения контрактов и управления закупками. Цель — получить лучшее соотношение цены, качества и надёжности.", example:"Отдел procurement провёл тендер среди 8 поставщиков и снизил стоимость закупки комплектующих на 15%.", related:[215,211]},
  {id:215, term:"Vendor Management", termEn:"Vendor Management / Управление поставщиками", category:"Управление цепями поставок", definition:"Систематический процесс оценки, контроля и развития поставщиков: мониторинг KPI (качество, сроки, цена), аудиты, рейтинги, совместное планирование. Снижает риски и повышает эффективность.", example:"Система vendor management ранжирует 50 поставщиков по 12 KPI: лучшие получают увеличенные заказы, худшие — план улучшений.", related:[214,222]},
  {id:216, term:"Lead Time (управление)", termEn:"Lead Time", category:"Управление цепями поставок", definition:"Полное время выполнения заказа от момента размещения до получения: время обработки заказа + производство + транспортировка + таможня + доставка. Ключевой параметр для расчёта страхового запаса.", example:"Lead time поставки из Китая: 3 дня производство + 18 дней логистика + 2 дня таможня = 23 дня.", related:[99,217,218]},
  {id:217, term:"Страховой запас", termEn:"Safety Stock", category:"Управление цепями поставок", definition:"Дополнительный запас товара на складе для защиты от непредвиденных колебаний спроса или задержек поставок. Рассчитывается на основе вариативности спроса, lead time и требуемого уровня сервиса.", example:"Safety stock в 500 единиц защитил от дефицита, когда поставка задержалась на 10 дней из-за шторма на Каспии.", related:[216,218,219]},
  {id:218, term:"Точка перезаказа", termEn:"Reorder Point", category:"Управление цепями поставок", definition:"Уровень запаса, при достижении которого необходимо разместить новый заказ поставщику. Рассчитывается: средний дневной спрос × lead time + safety stock. Автоматически генерируется в ERP-системе.", example:"Reorder point = 100 шт/день × 23 дня lead time + 500 шт safety stock = 2 800 штук.", related:[217,219,172]},
  {id:219, term:"Экономичный размер заказа (EOQ)", termEn:"Economic Order Quantity", category:"Управление цепями поставок", definition:"Оптимальный объём заказа, минимизирующий суммарные затраты на заказ (транспортировка, оформление) и хранение (аренда, страхование, порча). Формула Уилсона: EOQ = √(2DS/H).", example:"EOQ = 4 000 единиц. Заказ меньшего количества увеличит транспортные расходы, большего — стоимость хранения.", related:[218,217]},
  {id:220, term:"Just-in-Time (JIT)", termEn:"Just-in-Time", category:"Управление цепями поставок", definition:"Концепция управления запасами: поставка материалов точно в момент потребности, минимизируя складские запасы. Требует надёжных поставщиков и точного планирования. Разработана Toyota.", example:"Завод работает по JIT: комплектующие поступают за 2 часа до использования в производстве, склад минимален.", related:[221,217]},
  {id:221, term:"Lean Logistics", termEn:"Lean Logistics / Бережливая логистика", category:"Управление цепями поставок", definition:"Применение принципов бережливого производства к логистике: устранение потерь (ожидание, избыточные запасы, лишние перемещения), стандартизация процессов, постоянное улучшение (kaizen).", example:"Lean-проект на складе устранил 7 видов потерь: время комплектации снизилось на 40%, ошибки — на 85%.", related:[220,222]},
  {id:222, term:"Six Sigma в логистике", termEn:"Six Sigma in Logistics", category:"Управление цепями поставок", definition:"Методология управления качеством, направленная на снижение вариативности процессов до 3,4 дефекта на миллион операций. В логистике: сокращение ошибок в доставке, комплектации, документообороте.", example:"Проект Six Sigma по методу DMAIC снизил ошибки в комплектации с 2,5% до 0,1% (4,6 sigma).", related:[221,223]},
  {id:223, term:"KPI логистики", termEn:"Logistics KPIs", category:"Управление цепями поставок", definition:"Ключевые показатели эффективности логистических процессов: OTIF, fill rate, стоимость доставки на единицу, использование транспорта, оборачиваемость запасов, время цикла заказа.", example:"Dashboard KPI: OTIF 94,7%, fill rate 97,2%, стоимость доставки $3,20/кг, оборачиваемость запасов 8,5 раз/год.", related:[224,225,226]},
  {id:224, term:"OTIF", termEn:"On Time In Full", category:"Управление цепями поставок", definition:"Показатель «Вовремя и в полном объёме» — процент заказов, доставленных точно в срок и в полной комплектации. Ключевой KPI удовлетворённости клиентов. Мировой бенчмарк — 95%+.", example:"OTIF за март — 96,3%: из 1 200 заказов 1 155 доставлены вовремя и полностью.", related:[223,225]},
  {id:225, term:"Fill Rate", termEn:"Fill Rate / Коэффициент выполнения", category:"Управление цепями поставок", definition:"Процент заказов (или строк заказа), которые могут быть выполнены немедленно из текущего запаса. Показатель доступности товара на складе. Целевое значение: 95-98%.", example:"Fill rate 97%: из 5 000 заказанных позиций 4 850 были отгружены из наличия, 150 — в backorder.", related:[224,226,217]},
  {id:226, term:"Order Accuracy", termEn:"Order Accuracy / Точность выполнения заказа", category:"Управление цепями поставок", definition:"Процент заказов, выполненных без ошибок: правильный товар, количество, упаковка, маркировка, документация. Включает точность комплектации, упаковки и документооборота.", example:"Точность заказов выросла с 97,5% до 99,8% после внедрения системы pick-by-voice на складе.", related:[224,227]},
  {id:227, term:"Perfect Order Rate", termEn:"Perfect Order Rate", category:"Управление цепями поставок", definition:"Процент «идеальных» заказов — выполненных без единой ошибки по всем параметрам: вовремя, в полном объёме, без повреждений, с корректными документами. Мультиплицирует все KPI: OTIF × Accuracy × Damage-free × Invoice accuracy.", example:"Perfect order rate = 94% OTIF × 99% accuracy × 99,5% damage-free × 98% invoice = 90,6%.", related:[224,226]},
  {id:228, term:"Cash-to-Cash Cycle", termEn:"Cash-to-Cash Cycle Time", category:"Управление цепями поставок", definition:"Цикл «деньги — деньги»: время от оплаты поставщику до получения денег от клиента. Рассчитывается: дни запасов + дни дебиторки − дни кредиторки. Чем короче — тем эффективнее.", example:"Cash-to-cash cycle: 45 дней запасов + 30 дней дебиторки − 60 дней кредиторки = 15 дней.", related:[229,211]},
  {id:229, term:"Days of Inventory", termEn:"Days of Inventory / Дни запасов", category:"Управление цепями поставок", definition:"Среднее количество дней, в течение которых товар хранится на складе до продажи. Рассчитывается: (средний запас / себестоимость продаж) × 365. Чем меньше — тем быстрее оборот.", example:"Days of inventory сократился с 60 до 42 дней после оптимизации цепи поставок.", related:[228,217,84]},
  {id:230, term:"Возвратная логистика", termEn:"Reverse Logistics", category:"Управление цепями поставок", definition:"Управление потоком товаров от потребителя обратно к производителю или в пункт утилизации: возврат брака, рециклинг, ремонт, переработка упаковки. Растущий сегмент из-за экологических требований.", example:"Программа возвратной логистики обрабатывает 500 возвратов в месяц: 60% ремонт, 25% переработка, 15% утилизация.", related:[231,232]},
  {id:231, term:"Green Logistics", termEn:"Green Logistics / Зелёная логистика", category:"Управление цепями поставок", definition:"Экологически ответственный подход к логистике: снижение выбросов CO₂, использование альтернативных топлив, оптимизация маршрутов, экологичная упаковка, электротранспорт.", example:"Переход на СПГ-грузовики и оптимизация маршрутов сократили углеродный след логистики на 28%.", related:[230,232,233]},
  {id:232, term:"Circular Economy в логистике", termEn:"Circular Economy in Logistics", category:"Управление цепями поставок", definition:"Модель экономики замкнутого цикла: минимизация отходов, повторное использование материалов и упаковки, ремонт вместо замены. Логистика обеспечивает обратные потоки и переработку.", example:"Компания внедрила оборотную тару: 10 000 контейнеров используются повторно до 50 раз, экономя $200 000 в год.", related:[230,231]},
  {id:233, term:"Sustainable Supply Chain", termEn:"Sustainable Supply Chain / Устойчивая цепь поставок", category:"Управление цепями поставок", definition:"Цепь поставок, учитывающая экологические (ESG), социальные и экономические факторы. Включает аудит поставщиков, сокращение выбросов, справедливые условия труда, прозрачность.", example:"ESG-рейтинг цепи поставок повысился до A после аудита 200 поставщиков и перехода на возобновляемую энергию на складах.", related:[231,232,234]},
  {id:234, term:"Risk Management в логистике", termEn:"Supply Chain Risk Management", category:"Управление цепями поставок", definition:"Процесс выявления, оценки и минимизации рисков в цепи поставок: геополитические, климатические, операционные, финансовые, кибер-риски. Методы: диверсификация поставщиков, буферные запасы, страхование.", example:"Risk management выявил зависимость от единственного маршрута через Каспий — добавлен резервный маршрут через Турцию.", related:[235,211]},
  {id:235, term:"Business Continuity Planning (BCP)", termEn:"Business Continuity Planning", category:"Управление цепями поставок", definition:"Планирование непрерывности бизнеса — разработка стратегий и процедур для продолжения операций при серьёзных сбоях: пандемия, стихийные бедствия, кибератаки, блокировка маршрутов.", example:"BCP предусматривает 3 альтернативных маршрута, 2 резервных склада и запас критических товаров на 30 дней.", related:[234,211]},

  // === 7. ОПАСНЫЕ ГРУЗЫ И СПЕЦИАЛЬНЫЕ ПЕРЕВОЗКИ (20 terms) ===
  {id:236, term:"ADR (опасные грузы)", termEn:"ADR (European Agreement Dangerous Goods by Road)", category:"Опасные грузы", definition:"Европейское соглашение о международной дорожной перевозке опасных грузов. Определяет классификацию, упаковку, маркировку, требования к транспортным средствам и водителям. Обновляется каждые 2 года.", example:"Перевозка кислоты (класс 8) по ADR требует специального автомобиля, ДОПОГ-свидетельства водителя и аварийной карточки.", related:[43,237,238]},
  {id:237, term:"IMDG Code", termEn:"International Maritime Dangerous Goods Code", category:"Опасные грузы", definition:"Международный кодекс морской перевозки опасных грузов — обязательный стандарт IMO для классификации, упаковки, маркировки, размещения и документирования опасных грузов на судах.", example:"Контейнер с литиевыми батареями (IMDG Class 9) размещён на палубе согласно таблице сегрегации IMDG Code.", related:[236,238]},
  {id:238, term:"IATA DGR", termEn:"IATA Dangerous Goods Regulations", category:"Опасные грузы", definition:"Правила перевозки опасных грузов воздушным транспортом, издаваемые IATA. Самые строгие требования среди всех видов транспорта. Обновляются ежегодно. Включают перечень запрещённых и ограниченных веществ.", example:"По IATA DGR литиевые батареи ограничены: Packing Instruction 965-970, маркировка, Shipper's Declaration обязательна.", related:[29,22,236]},
  {id:239, term:"UN Number", termEn:"UN Number", category:"Опасные грузы", definition:"Четырёхзначный идентификационный номер, присвоенный ООН каждому опасному веществу или изделию. Используется во всех видах транспорта для однозначной идентификации. Всего более 3 500 UN-номеров.", example:"Бензин — UN 1203, класс 3 (легковоспламеняющаяся жидкость), группа упаковки II.", related:[240,236]},
  {id:240, term:"Класс опасности", termEn:"Hazard Class (1-9)", category:"Опасные грузы", definition:"Классификация опасных грузов по виду опасности: 1-Взрывчатые, 2-Газы, 3-Легковоспламеняющиеся жидкости, 4-Твёрдые, 5-Окисляющие, 6-Токсичные, 7-Радиоактивные, 8-Коррозионные, 9-Прочие.", example:"Аммиак — класс 2.3 (токсичный газ), подкласс 8 (коррозионный), UN 1005, требует спецтранспорт и ДОПОГ.", related:[239,241]},
  {id:241, term:"Группа упаковки", termEn:"Packaging Group (PG I, II, III)", category:"Опасные грузы", definition:"Уровень опасности вещества, определяющий требования к упаковке: PG I — высокая опасность (наиболее прочная упаковка), PG II — средняя, PG III — низкая. Не применяется к газам (класс 2) и взрывчатым (класс 1).", example:"Ацетон (UN 1090, класс 3, PG II) — средняя опасность: допускается стальная или пластиковая тара.", related:[240,242]},
  {id:242, term:"Маркировка опасных грузов", termEn:"Dangerous Goods Marking", category:"Опасные грузы", definition:"Система нанесения на упаковку и транспортное средство специальных знаков: UN-номер, наименование, знаки опасности (ромбы), стрелки ориентации, маркировка экологической опасности.", example:"На бочке с краской (UN 1263): ромб класса 3 (пламя), надпись UN 1263, группа упаковки III.", related:[243,241,239]},
  {id:243, term:"Знаки опасности", termEn:"Hazard Labels / Placards", category:"Опасные грузы", definition:"Стандартные ромбовидные знаки (100×100мм на упаковке, 250×250мм на транспорте), обозначающие класс опасности: пламя (кл.3), череп (кл.6.1), радиация (кл.7), коррозия (кл.8). Цвет зависит от класса.", example:"На контейнере размещены плакаты: ромб класса 3 (красный, пламя) и табличка с UN 1993 / знак 30.", related:[242,240]},
  {id:244, term:"MSDS / SDS", termEn:"Material Safety Data Sheet / Safety Data Sheet", category:"Опасные грузы", definition:"Паспорт безопасности вещества — документ с информацией о свойствах, опасностях, мерах первой помощи, условиях хранения и перевозки, средствах защиты, действиях при аварии. Обязателен для всех опасных веществ.", example:"SDS на серную кислоту: 16 разделов, включая pH, температуру вспышки, ПДК, средства нейтрализации при разливе.", related:[236,240]},
  {id:245, term:"Температурный режим", termEn:"Temperature-Controlled Logistics", category:"Опасные грузы", definition:"Требования к поддержанию определённой температуры при перевозке и хранении: охлаждённые (+2..+8°C), замороженные (-18..-25°C), глубокая заморозка (-60°C), контролируемая температура (+15..+25°C).", example:"Вакцины перевозятся в режиме +2..+8°C с непрерывным мониторингом и GPS-трекингом температуры.", related:[246,173]},
  {id:246, term:"Рефрижераторный контейнер", termEn:"Reefer Container", category:"Опасные грузы", definition:"Контейнер со встроенной холодильной установкой для перевозки грузов с температурным режимом. Диапазон: от -35°C до +30°C. Требует подключения к электропитанию (генсет или розетка на судне/терминале).", example:"Рефрижераторный контейнер 40'HC с мясом установлен на -18°C, подключён к генератору на автоплатформе.", related:[245,1,2]},
  {id:247, term:"Негабаритный груз", termEn:"Oversized Cargo / Out-of-Gauge (OOG)", category:"Опасные грузы", definition:"Груз, превышающий стандартные габариты контейнера или транспортного средства: ширина >2,44м, высота >2,59м, длина >12,03м. Требует специальных разрешений, маршрутов, сопровождения.", example:"Трансформатор 8×4×4,5м и весом 85 тонн доставлен на низкорамном трале с полицейским сопровождением.", related:[248,249,252]},
  {id:248, term:"Тяжеловесный груз", termEn:"Heavy Lift Cargo", category:"Опасные грузы", definition:"Грузы, требующие специальных грузоподъёмных средств: обычно свыше 5 тонн за единицу (для авиа — свыше 150 кг). Специальные краны, траверсы, спредеры. Детальный план погрузки обязателен.", example:"Для погрузки турбины весом 120 тонн использован плавучий кран грузоподъёмностью 300 тонн.", related:[247,249]},
  {id:249, term:"Project Cargo", termEn:"Project Cargo / Проектный груз", category:"Опасные грузы", definition:"Комплексная перевозка оборудования для крупных проектов: электростанции, заводы, буровые установки. Включает негабарит, тяжеловес, стандартные грузы. Требует детального инжиниринга, сюрвея маршрута.", example:"Project cargo для нефтеперерабатывающего завода: 450 мест, 12 000 тонн, 6 месяцев доставки из Кореи в Атырау.", related:[247,248,250]},
  {id:250, term:"Break Bulk", termEn:"Break Bulk / Генеральный груз", category:"Опасные грузы", definition:"Штучный груз, перевозимый не в контейнерах, а отдельными местами: мешки, бочки, ящики, трубы, металлопрокат, техника. Погрузка по единицам кранами или вилочными погрузчиками.", example:"500 тонн стальных труб перевезены break bulk на сухогрузе с погрузкой судовыми кранами.", related:[249,20]},
  {id:251, term:"Ro-Ro перевозка", termEn:"Roll-on/Roll-off Transport", category:"Опасные грузы", definition:"Перевозка колёсной техники (грузовики, трейлеры, спецтехника, автомобили) на специализированных судах с горизонтальной погрузкой через аппарель. Техника заезжает на борт своим ходом.", example:"50 грузовиков MAN заехали на Ro-Ro паром в Курыке и выехали в порту Алят за 45 минут.", related:[17,107]},
  {id:252, term:"OOG контейнер", termEn:"Out of Gauge Container", category:"Опасные грузы", definition:"Контейнер с грузом, выступающим за стандартные габариты: сверху (over-height), сбоку (over-width), с торцов (over-length). Размещается на flat rack или open top контейнерах. Занимает несколько слотов на судне.", example:"Генератор на flat rack выступает на 60 см по ширине — OOG, занимает 3 слота на судне, доплата $1 800.", related:[247,253,254]},
  {id:253, term:"Flat Rack контейнер", termEn:"Flat Rack Container", category:"Опасные грузы", definition:"Контейнер-платформа с торцевыми стенками (складными или фиксированными) без крыши и боковых стенок. Предназначен для негабаритных и тяжёлых грузов: техника, трубы, катушки, конструкции.", example:"Экскаватор весом 22 тонны размещён на 40' flat rack контейнере, закреплён цепями и стяжками.", related:[252,254,1]},
  {id:254, term:"Open Top контейнер", termEn:"Open Top Container", category:"Опасные грузы", definition:"Контейнер без жёсткой крыши (заменена тентом) для загрузки негабаритных грузов сверху краном. Боковые стенки стандартные. Используется для станков, оборудования, мрамора, стекла.", example:"4 мраморных блока по 8 тонн загружены в open top контейнер краном через верх.", related:[253,252,1]},
  {id:255, term:"Tank контейнер", termEn:"Tank Container / ISO Tank", category:"Опасные грузы", definition:"Контейнер-цистерна в стандартной раме ISO для перевозки жидкостей и газов: химикаты, пищевые масла, вино, СПГ. Объём 21 000-26 000 литров. Может быть с подогревом или теплоизоляцией.", example:"Tank контейнер с 24 000 литрами подсолнечного масла отправлен из Казахстана в Китай по ж/д.", related:[246,19,1]},

  // === 8. ПОРТЫ И ТЕРМИНАЛЫ (15 terms) ===
  {id:256, term:"Контейнерный терминал", termEn:"Container Terminal", category:"Порты и терминалы", definition:"Специализированный комплекс в порту для обработки контейнерных грузов: приём, хранение, перегрузка контейнеров между судами и наземным транспортом. Оборудован кранами STS, RTG, ричстакерами.", example:"Контейнерный терминал порта Актау обрабатывает до 100 000 TEU в год с помощью 2 кранов STS.", related:[257,263,264]},
  {id:257, term:"Причал", termEn:"Berth", category:"Порты и терминалы", definition:"Место у стенки порта для стоянки судна при проведении грузовых операций. Характеризуется длиной (метры), глубиной (осадка), оборудованием (краны), специализацией (контейнерный, нефтяной, паромный).", example:"Причал №3 порта Актау: длина 240м, глубина 6,5м, 2 крана STS, специализация — контейнеры.", related:[258,256]},
  {id:258, term:"Якорная стоянка", termEn:"Anchorage", category:"Порты и терминалы", definition:"Зона в акватории порта, где суда стоят на якоре в ожидании свободного причала, благоприятной погоды или таможенного разрешения. Время ожидания на рейде увеличивает расходы.", example:"Судно простояло на якорной стоянке 3 дня в ожидании причала, расходы — $15 000.", related:[257,140]},
  {id:259, term:"Портовые сборы", termEn:"Port Dues / Port Charges", category:"Порты и терминалы", definition:"Совокупность обязательных платежей за использование портовой инфраструктуры: корабельный сбор, причальный, маячный, навигационный, экологический, санитарный. Рассчитываются от валовой вместимости судна.", example:"Портовые сборы за заход контейнеровоза 5 000 GT в Актау: $4 200 (корабельный + причальный + навигационный).", related:[260,257]},
  {id:260, term:"THC", termEn:"Terminal Handling Charges", category:"Порты и терминалы", definition:"Терминальные расходы по обработке контейнера в порту: перемещение от борта судна до контейнерной площадки (или обратно), хранение в пределах free time. Включаются в стоимость перевозки или оплачиваются отдельно.", example:"THC в порту Актау: $150 за 20' контейнер и $220 за 40' контейнер, включая 5 дней бесплатного хранения.", related:[261,259,256]},
  {id:261, term:"Free Time", termEn:"Free Time / Бесплатное хранение", category:"Порты и терминалы", definition:"Период бесплатного хранения контейнера на терминале после выгрузки с судна (для импорта) или до погрузки на судно (для экспорта). Обычно 5-7 дней. По истечении — демередж.", example:"Free time в Актау — 7 дней. На 8-й день начисляется демередж $50/день за 20' и $80/день за 40'.", related:[5,143,260]},
  {id:262, term:"CFS", termEn:"Container Freight Station", category:"Порты и терминалы", definition:"Контейнерная грузовая станция — склад при порту или терминале для консолидации/расконсолидации сборных контейнеров (LCL). Мелкие партии от разных отправителей загружаются в один контейнер.", example:"На CFS в Поти груз из 6 отправок был консолидирован в один 40' контейнер для отправки в Актау.", related:[263,95,47]},
  {id:263, term:"CY (Container Yard)", termEn:"Container Yard", category:"Порты и терминалы", definition:"Контейнерная площадка — открытая территория терминала для штабелирования и хранения контейнеров. Контейнеры размещаются в блоках по 4-5 ярусов. Управляется через систему позиционирования.", example:"На CY порта Актау одновременно хранится до 3 000 TEU, контейнеры штабелируются в 4 яруса.", related:[256,262,32]},
  {id:264, term:"Портальный кран (STS)", termEn:"Ship-to-Shore Gantry Crane (STS)", category:"Порты и терминалы", definition:"Судовой перегрузочный кран — крупный портальный кран для погрузки/выгрузки контейнеров с судна. Вылет стрелы 40-65м, грузоподъёмность 40-65 тонн. Производительность 25-35 контейнеров в час.", example:"Новый кран STS в Актау с вылетом 50м обрабатывает суда шириной до 13 рядов контейнеров.", related:[265,256]},
  {id:265, term:"RTG (козловой кран)", termEn:"Rubber Tyred Gantry Crane (RTG)", category:"Порты и терминалы", definition:"Козловой кран на пневмоколёсах для штабелирования контейнеров на контейнерной площадке. Перекрывает 6-7 рядов контейнеров и 1 полосу движения. Грузоподъёмность 40-50 тонн.", example:"5 кранов RTG обслуживают контейнерную площадку, перемещая контейнеры между штабелями и автотранспортом.", related:[264,266]},
  {id:266, term:"Ричстакер", termEn:"Reach Stacker", category:"Порты и терминалы", definition:"Контейнерный погрузчик с телескопическим захватом (спредером) для работы с контейнерами. Штабелирует контейнеры в 5 рядов. Более мобилен, чем RTG, но менее производителен.", example:"Ричстакер Kalmar перемещает 40' контейнер весом 30 тонн со скоростью 20 движений в час.", related:[265,256]},
  {id:267, term:"Осадка судна", termEn:"Draft / Draught", category:"Порты и терминалы", definition:"Глубина погружения корпуса судна в воду, измеряемая от ватерлинии до нижней точки киля. Определяет, может ли судно войти в порт. Зависит от загрузки, плотности воды (море/река), дифферента.", example:"Осадка загруженного сухогруза — 6,2м, а глубина у причала Актау — 6,5м: проход возможен с запасом 0,3м.", related:[257,268]},
  {id:268, term:"Лоцманская проводка", termEn:"Pilotage", category:"Порты и терминалы", definition:"Обязательная навигационная услуга: лоцман поднимается на борт и проводит судно через акваторию порта, каналы, узкости. Лоцман знает местные условия: глубины, течения, особенности причалов.", example:"Лоцман провёл контейнеровоз через фарватер порта Актау, стоимость лоцманской проводки — $800.", related:[269,259]},
  {id:269, term:"Буксировка (портовая)", termEn:"Tug Assistance", category:"Порты и терминалы", definition:"Портовые буксиры помогают крупным судам при швартовке к причалу и отходе от него. Количество буксиров (1-4) зависит от размера судна, погоды и условий порта.", example:"Два буксира мощностью по 3 000 л.с. пришвартовали контейнеровоз к причалу №2 за 40 минут.", related:[268,257]},
  {id:270, term:"Портовое агентирование", termEn:"Port Agency / Ship Agency", category:"Порты и терминалы", definition:"Услуги агента, представляющего интересы судовладельца в порту: организация захода судна, оформление документов, заказ лоцмана и буксиров, снабжение, взаимодействие с таможней и портовыми властями.", example:"Портовый агент в Актау организовал заход судна: лоцман, 2 буксира, таможня, бункеровка — всё за 4 часа.", related:[268,269,259]}
]